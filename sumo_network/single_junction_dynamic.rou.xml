<routes>
    <vType id="car" vClass="passenger" guiShape="passenger"
           color="100,149,237" length="4.5" width="1.8" maxSpeed="13.9"/>
    <vType id="threewheeler" vClass="moped" guiShape="motorcycle"
           color="255,165,0" length="2.2" width="1.2" maxSpeed="11.0"/>
    <vType id="truck" vClass="truck" guiShape="truck"
           color="128,128,128" length="7.5" width="2.5" maxSpeed="11.5"/>
    <vType id="emergency" vClass="emergency" guiShape="emergency"
           color="255,0,0" length="6.5" width="2.4" maxSpeed="22.0"
           emergencyDecel="9.0" speedFactor="1.5"/>

    <!-- New: Two-Wheeler (Motorcycle/Scooter) -->
    <vType id="twowheeler" vClass="motorcycle" guiShape="motorcycle"
           color="50,205,50" length="1.8" width="0.8" maxSpeed="16.6"/>

    <!-- New: Auto-Rickshaw -->
    <vType id="autorickshaw" vClass="moped" guiShape="delivery"
           color="255,215,0" length="2.6" width="1.3" maxSpeed="12.5"/>

    <!-- Background flow to keep simulation alive -->
    <flow id="background_ns" type="car" begin="0" end="3600" vehsPerHour="30" departLane="best" departSpeed="max">
        <route edges="north_in south_out"/>
    </flow>
    <flow id="background_ew" type="car" begin="0" end="3600" vehsPerHour="30" departLane="best" departSpeed="max">
        <route edges="east_in west_out"/>
    </flow>
</routes>
