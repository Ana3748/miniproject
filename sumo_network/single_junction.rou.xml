<routes>
    <!-- ═══════════════════════════════════════════════════════════════════
         Vehicle Types
    ════════════════════════════════════════════════════════════════════ -->
    <vType id="car"  vClass="passenger" guiShape="passenger"
           color="100,149,237" length="4.5" width="1.8" maxSpeed="13.9"/>
    <vType id="car2" vClass="passenger" guiShape="passenger"
           color="144,238,144" length="4.5" width="1.8" maxSpeed="13.9"/>
    <vType id="car3" vClass="passenger" guiShape="passenger"
           color="255,218,185" length="4.5" width="1.8" maxSpeed="13.9"/>

    <!-- Emergency vehicle: bright red, ambulance shape -->
    <vType id="emergency" vClass="emergency" guiShape="emergency"
           color="255,0,0" length="6.5" width="2.4" maxSpeed="22.0"
           emergencyDecel="9.0" speedFactor="1.5"/>

    <!-- Additional types for YOLO mapping -->
    <vType id="truck" vClass="truck" guiShape="truck" color="128,128,128" length="7.5" width="2.5" maxSpeed="11.5"/>
    <vType id="bus" vClass="bus" guiShape="bus" color="0,0,255" length="12.0" width="2.5" maxSpeed="15.0"/>
    <vType id="bicycle" vClass="bicycle" guiShape="bicycle" color="255,0,255" length="1.6" width="0.6" maxSpeed="5.5"/>
    <vType id="threewheeler" vClass="moped" guiShape="motorcycle" color="255,165,0" length="2.2" width="1.2" maxSpeed="11.0"/>
    <vType id="twowheeler" vClass="motorcycle" guiShape="motorcycle" color="50,205,50" length="1.8" width="0.8" maxSpeed="16.6"/>

    <!-- ═══════════════════════════════════════════════════════════════════
         CONTINUOUS FLOWS — vehicles spawn every N seconds for full 3600s
         vehsPerHour: roughly how many vehicles per hour on that approach
         Adjust these numbers to simulate light/heavy traffic per direction.
    ════════════════════════════════════════════════════════════════════ -->

    <!-- North → South  (straight through) -->
    <flow id="f_NS"  type="car"  begin="0" end="3600" vehsPerHour="50" departLane="best" departSpeed="max">
        <route edges="north_in south_out"/>
    </flow>
    <flow id="f_NS2" type="car2" begin="0" end="3600" vehsPerHour="30" departLane="best" departSpeed="max">
        <route edges="north_in south_out"/>
    </flow>

    <!-- South → North  (straight through) -->
    <flow id="f_SN"  type="car"  begin="0" end="3600" vehsPerHour="40" departLane="best" departSpeed="max">
        <route edges="south_in north_out"/>
    </flow>
    <flow id="f_SN2" type="car3" begin="0" end="3600" vehsPerHour="20" departLane="best" departSpeed="max">
        <route edges="south_in north_out"/>
    </flow>

    <!-- East → West  (straight through) -->
    <flow id="f_EW"  type="car3" begin="0" end="3600" vehsPerHour="60" departLane="best" departSpeed="max">
        <route edges="east_in west_out"/>
    </flow>
    <flow id="f_EW2" type="car"  begin="0" end="3600" vehsPerHour="40" departLane="best" departSpeed="max">
        <route edges="east_in west_out"/>
    </flow>

    <!-- West → East  (straight through) -->
    <flow id="f_WE"  type="car2" begin="0" end="3600" vehsPerHour="60" departLane="best" departSpeed="max">
        <route edges="west_in east_out"/>
    </flow>
    <flow id="f_WE2" type="car3" begin="0" end="3600" vehsPerHour="30" departLane="best" departSpeed="max">
        <route edges="west_in east_out"/>
    </flow>

    <!-- ── Turning flows ──────────────────────────────────────────────── -->
    <!-- North → East (right turn) -->
    <flow id="f_NE" type="car"  begin="0" end="3600" vehsPerHour="20" departLane="best" departSpeed="max">
        <route edges="north_in east_out"/>
    </flow>
    <!-- South → West (right turn) -->
    <flow id="f_SW" type="car2" begin="0" end="3600" vehsPerHour="20" departLane="best" departSpeed="max">
        <route edges="south_in west_out"/>
    </flow>
    <!-- East → North (left turn) -->
    <flow id="f_EN" type="car3" begin="0" end="3600" vehsPerHour="15" departLane="best" departSpeed="max">
        <route edges="east_in north_out"/>
    </flow>
    <!-- West → South (left turn) -->
    <flow id="f_WS" type="car"  begin="0" end="3600" vehsPerHour="15" departLane="best" departSpeed="max">
        <route edges="west_in south_out"/>
    </flow>

    </routes>